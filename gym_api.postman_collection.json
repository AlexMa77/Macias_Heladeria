{
  "info": {
    "_postman_id": "a1b2c3d4-eeee-ffff-0000-111122223333",
    "name": "Heladeria API — FitZone (Django + Postgres + JWT)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://127.0.0.1:8000" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Public) — POST /api/auth/register/",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register/", "host": ["{{baseUrl}}"], "path": ["api","auth","register",""] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"email\": \"user1@mail.com\",\n  \"password\": \"123456\"\n}" }
          }
        },
        {
          "name": "Login (JWT) — POST /api/auth/login/ (guarda tokens)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "let d={};try{d=pm.response.json();}catch(e){}",
            "if(d.access){pm.collectionVariables.set('accessToken',d.access);pm.environment.set('accessToken',d.access);}",
            "if(d.refresh){pm.collectionVariables.set('refreshToken',d.refresh);pm.environment.set('refreshToken',d.refresh);}",
            "pm.test('Token recibido',function(){pm.expect(d.access).to.be.a('string');});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login/", "host": ["{{baseUrl}}"], "path": ["api","auth","login",""] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}" }
          }
        },
        {
          "name": "Refresh — POST /api/auth/refresh/",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "let d={};try{d=pm.response.json();}catch(e){}",
            "if(d.access)pm.collectionVariables.set('accessToken',d.access);",
            "pm.test('Token refrescado',function(){pm.expect(d.access).to.be.a('string');});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh/", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh",""] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Postgres — Helados",
      "item": [
        {
          "name": "List helados — GET /api/helados/",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/helados/", "host": ["{{baseUrl}}"], "path": ["api","helados",""] }
          }
        },
        {
          "name": "Create helado — POST /api/helados/",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/helados/", "host": ["{{baseUrl}}"], "path": ["api","helados",""] },
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Helado\",\n  \"precio\": 35.00,\n  \"activo\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "Postgres — Clientes",
      "item": [
        {
          "name": "List clientes (Public) — GET /api/clientes/",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/clientes/", "host": ["{{baseUrl}}"], "path": ["api","clientes",""] }
          }
        },
        {
          "name": "Create cliente (Admin) — POST /api/clientes/",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/clientes/", "host": ["{{baseUrl}}"], "path": ["api","clientes",""] },
            "body": { "mode": "raw", "raw": "{\n  \"helado\": 1,\n  \"nombre\": \"Carlos Pérez\",\n  \"cedula\": \"1712345678\",\n  \"dias_atraso\": 0,\n  \"activo\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "Servicios — FOR / WHILE",
      "item": [
        {
          "name": "Cobros (FOR) — POST /api/heladeria/cobros/",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/heladeria/cobros/", "host": ["{{baseUrl}}"], "path": ["api","heladeria","cobros",""] },
            "body": { "mode": "raw", "raw": "{\n  \"clientes\": [\n    { \"nombre\": \"Ana Torres\",  \"cuota\": 35.00, \"dias_atraso\": 0  },\n    { \"nombre\": \"Luis Mora\",   \"cuota\": 35.00, \"dias_atraso\": 5  },\n    { \"nombre\": \"Pedro Reyes\", \"cuota\": 35.00, \"dias_atraso\": 10 },\n    { \"nombre\": \"María Vega\",  \"cuota\": 35.00, \"dias_atraso\": 20 }\n  ]\n}" }
          }
        },
        {
          "name": "Clases (WHILE) — GET /api/heladeria/clases/",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/heladeria/clases/?minutos_disponibles=180&duraciones=45,60,45,30,60",
              "host": ["{{baseUrl}}"],
              "path": ["api","heladeria","clases",""],
              "query": [
                { "key": "minutos_disponibles", "value": "180" },
                { "key": "duraciones",          "value": "45,60,45,30,60" }
              ]
            }
          }
        }
      ]
    }
  ]
}